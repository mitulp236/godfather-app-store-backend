# ---- Server ----
PORT=4100
NODE_ENV=development

# Everything is mounted under this prefix:
#   <BASE_PATH>/api    → JSON API
#   <BASE_PATH>/admin  → admin panel
BASE_PATH=/godfather-app-store

# ---- MongoDB Atlas ----
# Full connection string. The database name is applied from MONGODB_DB_NAME below,
# so keep the URI itself free of a trailing /<dbname>.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=godfather_app_store

# ---- Admin ----
# Shared secret for scripted access to /api/admin/* (curl, CI, the seed script).
# Send it as the header:  x-admin-key: <value>
# The browser admin panel signs in with a session cookie instead and ignores this.
# Generate one with:      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=change-me-to-a-long-random-string

# How long an admin panel sign-in lasts.
SESSION_TTL_DAYS=30

# ---- CORS ----
# Comma-separated list of allowed origins, or * to allow all.
# The TV app runs from the capacitor:// / http://localhost origin, so * is usually what you want.
CORS_ORIGIN=*
